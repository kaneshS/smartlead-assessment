DATABASE_URL=postgres://sendworker:sendworker@localhost:5432/sendworker

# Worker
WORKER_ID=worker-1
WORKER_BATCH_SIZE=10
WORKER_POLL_INTERVAL_MS=500
WORKER_LEASE_TTL_SECONDS=60
WORKER_MAX_ATTEMPTS=5
WORKER_SHUTDOWN_TIMEOUT_MS=30000
METRICS_SUMMARY_INTERVAL_MS=30000

# Simulated provider (rates must sum to ~1.0)
PROVIDER_SUCCESS_RATE=0.80
PROVIDER_TRANSIENT_RATE=0.12
PROVIDER_THROTTLED_RATE=0.05
PROVIDER_HARD_BOUNCE_RATE=0.03
PROVIDER_AMBIGUOUS_RATE=0.01
PROVIDER_LATENCY_MIN_MS=50
PROVIDER_LATENCY_MAX_MS=250
PROVIDER_RNG_SEED=

# Seed
SEED_MAILBOXES=50
SEED_CAMPAIGNS=10
SEED_EMAILS=10000
SEED_DUE_RATIO=0.9
